{
  "name": "@repo/ui",
  "version": "0.0.0",
  "private": true,
  "exports": {
    "./*": "./src/*.tsx",
    "./lib": "./src/lib/index.ts",
    "./styles": "./dist/index.css",
    "./theme": "./src/styles/theme.css"
  },
  "scripts": {
    "dev": "tailwindcss -i ./src/styles/index.css -o ./dist/index.css --watch",
    "build": "tailwindcss -i ./src/styles/index.css -o ./dist/index.css --minify",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "generate:component": "turbo gen react-component",
    "check-types": "tsc --noEmit"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@tailwindcss/cli": "^4.2.1",
    "@types/node": "^22.15.3",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "eslint": "^9.39.1",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "1.4.0",
    "typescript": "5.9.2"
  },
  "dependencies": {
    "class-variance-authority": "0.7.1",
    "clsx": "^2.1.1",
    "radix-ui": "1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0"
  }
}
