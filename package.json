{
  "name": "renly",
  "version": "1.0.0",
  "description": "Renly — personal finance app (investments, income/expenses)",
  "private": true,
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:docker": "docker compose up -d",
    "build": "turbo run build",
    "start": "turbo run start --parallel",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "pnpm format:web && pnpm format:api",
    "format:check": "pnpm format:check:web && pnpm format:check:api",
    "format:api": "pnpm --filter api run format",
    "format:check:api": "pnpm --filter api run format:check",
    "format:web": "prettier --write .",
    "format:check:web": "prettier --check .",
    "check-types": "turbo run check-types",
    "check:api": "pnpm --filter api run check",
    "check:web": "pnpm --filter web run check-types",
    "clean": "pnpm --recursive exec rm -rf node_modules .next dist",
    "install:all": "pnpm install",
    "dev:api": "pnpm --filter api run dev",
    "dev:ui": "pnpm --filter @repo/ui run dev",
    "dev:web": "pnpm --filter web run dev",
    "build:api": "pnpm --filter api run build",
    "build:ui": "pnpm --filter @repo/ui run build",
    "build:web": "pnpm --filter web run build",
    "prepare": "husky",
    "db:init": "node scripts/db-init.mjs",
    "db:fork": "node scripts/db-fork.mjs"
  },
  "lint-staged": {
    "apps/api/**/*.py": [
      "bash scripts/ruff-check-fix.sh",
      "pnpm --filter api run format"
    ],
    "apps/web/**/*.{ts,tsx,js,jsx}": [
      "pnpm --filter web run lint:fix",
      "prettier --write"
    ],
    "packages/ui/**/*.{ts,tsx,js,jsx}": [
      "pnpm --filter @repo/ui run lint:fix",
      "prettier --write"
    ],
    "**/*.{json,md,css,scss,html,yml,yaml,mjs}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.7.4",
    "turbo": "^2.8.13",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": ">=22"
  }
}
