# NextAuth (when implemented)
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# API base URL (for client-side requests)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Fallback currencies shown in the sidebar switch when no settings saved yet
NEXT_PUBLIC_FALLBACK_PRIMARY_CURRENCY=ARS
NEXT_PUBLIC_FALLBACK_SECONDARY_CURRENCY=USD

# Dashboard period presets (up to 4). "All" is always appended as the last option.
# Format: NM = N months (e.g. 1M, 3M, 6M), NY = N years (e.g. 1Y, 2Y), YTD = year to date.
# Note: YTD = Jan 1 of current year → today. 1Y = 12 months back → today. They differ.
# If omitted, defaults to: 1M, 3M, 6M, YTD, All.
# NEXT_PUBLIC_PERIOD_PRESET_1=1M
# NEXT_PUBLIC_PERIOD_PRESET_2=3M
# NEXT_PUBLIC_PERIOD_PRESET_3=6M
# NEXT_PUBLIC_PERIOD_PRESET_4=YTD

# Maximum groups per user (soft limit — shows warning when approaching). Default: 50.
# NEXT_PUBLIC_MAX_GROUPS=50

# Percentage of max groups at which the warning appears. Default: 80.
# NEXT_PUBLIC_GROUP_LIMIT_WARNING_PCT=80
